  shirt:    new Set(['neckBaseGirth','height','bustGirth','waistGirth','hipGirth','backNeckToWaist','acrossBackWidth','shoulderLength','outerArmLength','upperArmLength','shirtLength','acrossBackShoulderWidth','upperBicepGirth','wristGirth']),
