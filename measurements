// ── Google sign-in ────────────────────────────────────────────────────────────
function signInGoogle() {
  clearAuthMessages();

  if (!window.MT || !window.MT.signInWithPopup) {
    showAuthError('Still loading — please try again in a moment.');
    return;
  }

  // signInWithPopup MUST be called synchronously inside a user gesture (click)
  // to work in Safari and inside iframes. Do NOT await before calling it.
  var provider = window.MT.googleProvider;
  provider.setCustomParameters({ prompt: 'select_account' });

  window.MT.signInWithPopup(window.MT.auth, provider)
    .then(function(result) {
      // onAuthStateChanged will handle the rest
    })
    .catch(function(e) {
      console.error('Google sign-in error:', e.code, e.message);
      if (e.code === 'auth/popup-blocked') {
        // Popup was blocked — fall back to redirect
        showAuthError('Popup blocked. Redirecting to Google...');
        setTimeout(function() {
          window.MT.signInWithRedirect(window.MT.auth, window.MT.googleProvider);
        }, 1000);
      } else if (e.code !== 'auth/popup-closed-by-user' && e.code !== 'auth/cancelled-popup-request') {
        showAuthError(friendlyError(e.code));
      }
    });
}

