function makeField(key, label) {
  const wrap = document.createElement('div');
  wrap.className = 'field'; wrap.dataset.key = key;

  const lbl = document.createElement('label');
  lbl.className = 'field-lbl';

  const txt = document.createElement('span');
  txt.textContent = label;
  lbl.appendChild(txt);

  if (HAS_INFO.has(key)) {
    const btn = document.createElement('button');
    btn.type = 'button'; btn.className = 'field-info-btn';
    btn.setAttribute('aria-label', 'Show guide');
    btn.innerHTML =
      `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">` +
      `<circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/>` +
      `<line x1="12" y1="8" x2="12.01" y2="8"/></svg>` +
      `<div class="field-info-popup"><p>Measurement guide image would appear here.</p></div>`;
    btn.onclick = e => {
      e.preventDefault(); e.stopPropagation();
      document.querySelectorAll('.field-info-btn.open').forEach(b => { if (b !== btn) b.classList.remove('open'); });
      btn.classList.toggle('open');
    };
    lbl.appendChild(btn);
  }

  wrap.appendChild(lbl);

  const inp = document.createElement('input');
  inp.type = 'number'; inp.id = 'f-' + key; inp.name = key;
  inp.step = '0.1'; inp.min = '0'; inp.max = '999'; inp.placeholder = '0.0';
  inp.addEventListener('focus', () => setFieldFocus(key));
  wrap.appendChild(inp);
  return wrap;
}

