  ['upperHipBreadth','Upper hip breadth (cm)'],['frontShoulderWidth','Front shoulder width (cm)'],['chestWidth','Chest width (cm)'],
  ['shoulderLength','Shoulder length (cm)'],['shoulderSlope','Shoulder slope (cm)'],['neckBaseWidth','Neck base width (cm)'],
  ['waistToHipLength','Waist to hip length (cm)'],['waistToKneeLength','Waist to knee length (cm)'],
