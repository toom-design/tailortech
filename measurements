async function handleFormSubmit(e) {
  e.preventDefault();
  const form = document.getElementById('mform');
  if (!form.checkValidity()) { form.reportValidity(); return; }

  const user = window.MT.currentUser;
  if (!user) { toast('You must be signed in to save.', 'error'); return; }

  // Collect all form values
  const data = { garment: currentFilter, dateTime: new Date().toLocaleString() };
  new FormData(form).forEach((v, k) => { if (v) data[k] = v; });

  // Set save button loading
  document.getElementById('save-label').style.display   = 'none';
  document.getElementById('save-spinner').style.display = 'block';
  document.getElementById('btn-save').disabled          = true;

  try {
    const res = await window.MT.sheetsRequest('saveMeasurement', { data });
    if (res.success) {
      toast('Measurements saved successfully!');
      showScreen('dashboard');
      loadMeasurementRecords(user.email);
    } else {
      toast(res.message || 'Failed to save. Check your API URL.', 'error');
    }
  } catch(err) {
    toast('Network error. Check your Apps Script URL.', 'error');
  } finally {
    document.getElementById('save-label').style.display   = '';
    document.getElementById('save-spinner').style.display = 'none';
    document.getElementById('btn-save').disabled          = false;
  }
}

